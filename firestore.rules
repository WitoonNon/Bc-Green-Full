rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to get user data safely
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if user has a specific role
    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == role;
    }

    function isTechnician() {
      return hasRole("technician");
    }

    function isAdmin() {
      return hasRole("admin");
    }

    function isStaff() {
      return isTechnician() || isAdmin();
    }

    function isOwner(ticketId) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'guest' &&
             resource.data.userId == request.auth.uid;
    }

    match /system/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow create, read, update: if isSignedIn();
      allow delete: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow create, read, update: if isSignedIn();
      allow delete: if isStaff();
    }

    match /faqs/{faqId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /manuals/{manualId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /promotions/{promoId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /announcements/{announceId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /vehicles/{vehicleId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if request.auth.uid == userId || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
