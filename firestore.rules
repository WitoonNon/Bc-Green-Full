rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isTechnician() {
      return isSignedIn()
        && userDoc().exists()
        && userDoc().data.role == "technician";
    }

    function isAdmin() {
      return isSignedIn()
        && userDoc().exists()
        && userDoc().data.role == "admin";
    }

    function isStaff() {
      return isTechnician() || isAdmin();
    }

    function isOwner(resource) {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function changedKeysOnly(keys) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(keys);
    }

    function seedOpen() {
      return !exists(/databases/$(database)/documents/system/bootstrap);
    }

    function isSeedDoc() {
      return request.resource.data.seed == true;
    }

    function hasCompleteAddress() {
      return isSignedIn()
        && userDoc().exists()
        && userDoc().data.address is map
        && userDoc().data.address.line1 is string
        && userDoc().data.address.district is string
        && userDoc().data.address.province is string
        && userDoc().data.address.zip is string
        && userDoc().data.address.line1.size() > 0
        && userDoc().data.address.district.size() > 0
        && userDoc().data.address.province.size() > 0
        && userDoc().data.address.zip.size() > 0;
    }

    match /system/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /tickets/{ticketId} {
      allow create, read, update: if isSignedIn();
      allow delete: if isOwner(resource) || isStaff();
    }

    match /notifications/{notificationId} {
      allow create, read, update: if isSignedIn();
      allow delete: if isStaff();
    }

    match /faqs/{faqId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isStaff();
    }

    match /manuals/{manualId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isStaff();
    }

    match /promotions/{promoId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isStaff();
    }

    match /announcements/{announceId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isStaff();
    }

    match /vehicles/{vehicleId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /users/{userId} {
      allow create, read, update: if isSignedIn();
      allow delete: if false;
    }
  }
}
